# ============================================================================
# HOSTELWISE AI - Environment Configuration Example
# Copy this file to '.env' and fill in your credentials.
# ============================================================================

# Gemini AI Configuration
# Required to enable the Gemini Financial Assistant.
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Platform Configuration
# (Optional - If left blank, the application will run in local fallback mode)
GCP_PROJECT=your_gcp_project_id_here
GCS_BUCKET_NAME=hostelwise-raw-expenses
BIGQUERY_DATASET=hostelwise_ai_dataset

# Application Environment
# Options: development, production
HOSTELWISE_ENV=development
